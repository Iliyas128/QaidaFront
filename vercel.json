{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://185.113.132.17/api/$1" },
    { "source": "/((?!assets|api|sw.js|manifest.json|icon-192.png).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
